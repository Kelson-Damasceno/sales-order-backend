{
  "compilerOptions": {
    "target": "ES2024",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "rootDir": "./",
    "rootDirs": ["srv", "db"],
    "paths": {
      "@models/*": ["./@cds-models/*/index.ts"],
      "@/*": ["./srv/*"],
      "@db/*": ["src/db/*"]  
    }
  },

  "include": [
    "srv",
    "src",
    "types",
    "db"
    
  
  ],

  "exclude": ["node_modules"],

}
